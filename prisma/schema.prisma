generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  USER
  MODERATOR
  ADMIN
}

enum ArticleStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  UNPUBLISHED
  ARCHIVED
  DELETED
}

enum ArticleVisibility {
  PUBLIC
  UNLISTED
  PRIVATE
}

enum ReportStatus {
  PENDING
  REVIEWING
  RESOLVED
  REJECTED
}

enum ReportReason {
  SPAM
  HARASSMENT
  HATE_SPEECH
  MISINFORMATION
  COPYRIGHT
  ADULT_CONTENT
  VIOLENCE
  OTHER
}

enum NotificationType {
  ARTICLE_LIKED
  ARTICLE_COMMENTED
  ARTICLE_BOOKMARKED
  AUTHOR_FOLLOWED
  REPORT_UPDATED
  SYSTEM
}

enum UploadPurpose {
  ARTICLE_COVER
  PROFILE_IMAGE
  EDITOR_IMAGE
}

enum ContactTopic {
  SUPPORT
  PARTNERSHIP
  SECURITY
  DEMO
  OTHER
}

enum ContactMessageStatus {
  PENDING
  IN_PROGRESS
  RESOLVED
  ARCHIVED
}

model User {
  id                String               @id @default(cuid())
  name              String
  username          String               @unique
  email             String               @unique
  emailVerified     DateTime?
  passwordHash      String?
  image             String?
  bio               String?
  role              UserRole             @default(USER)
  isActive          Boolean              @default(true)
  isSuspended       Boolean              @default(false)
  suspensionReason  String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  lastLoginAt       DateTime?
  articles          Article[]
  comments          Comment[]
  likes             Like[]
  bookmarks         Bookmark[]
  bookmarkCollections BookmarkCollection[]
  followers         Follow[]             @relation("followers")
  following         Follow[]             @relation("following")
  notifications     Notification[]
  reports           Report[]             @relation("reporterReports")
  reviewedReports   Report[]             @relation("reviewerReports")
  articleViews      ArticleView[]
  auditLogs         AuditLog[]
  accounts          Account[]
  sessions          Session[]
  revisions         ArticleRevision[]
  activities        ArticleActivity[]
  uploads           Upload[]
  handledContactMessages ContactMessage[] @relation("contactHandler")

  @@index([role, isActive, isSuspended])
  @@index([createdAt])
}

model Article {
  id                 String             @id @default(cuid())
  authorId           String
  categoryId         String?
  title              String
  slug               String             @unique
  subtitle           String?
  excerpt            String?
  content            String
  sanitizedContent   String
  coverImage         String?
  coverImagePublicId String?
  status             ArticleStatus      @default(DRAFT)
  visibility         ArticleVisibility  @default(PUBLIC)
  featured           Boolean            @default(false)
  pinned             Boolean            @default(false)
  readingTime        Int                @default(0)
  wordCount          Int                @default(0)
  viewCount          Int                @default(0)
  likeCount          Int                @default(0)
  commentCount       Int                @default(0)
  bookmarkCount      Int                @default(0)
  seoTitle           String?
  seoDescription     String?
  canonicalUrl       String?
  publishedAt        DateTime?
  scheduledAt        DateTime?
  archivedAt         DateTime?
  deletedAt          DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  author             User               @relation(fields: [authorId], references: [id], onDelete: Cascade)
  category           Category?          @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  tags               ArticleTag[]
  comments           Comment[]
  likes              Like[]
  bookmarks          Bookmark[]
  views              ArticleView[]
  revisions          ArticleRevision[]
  reports            Report[]
  activityLogs       ArticleActivity[]

  @@index([status, publishedAt])
  @@index([authorId, updatedAt])
  @@index([categoryId, publishedAt])
  @@index([visibility, publishedAt])
  @@index([scheduledAt, status])
}

model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  description String?
  image       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  articles    Article[]
}

model Tag {
  id        String       @id @default(cuid())
  name      String       @unique
  slug      String       @unique
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  articles  ArticleTag[]
}

model ArticleTag {
  articleId  String
  tagId      String
  assignedAt DateTime @default(now())
  article    Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([articleId, tagId])
  @@index([tagId, articleId])
}

model Comment {
  id        String    @id @default(cuid())
  articleId String
  authorId  String
  parentId  String?
  content   String
  isEdited  Boolean   @default(false)
  isHidden  Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  article   Article   @relation(fields: [articleId], references: [id], onDelete: Cascade)
  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent    Comment?  @relation("commentReplies", fields: [parentId], references: [id], onDelete: SetNull)
  replies   Comment[] @relation("commentReplies")
  reports   Report[]

  @@index([articleId, createdAt])
  @@index([parentId, createdAt])
}

model Like {
  userId    String
  articleId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@id([userId, articleId])
}

model Bookmark {
  userId      String
  articleId   String
  collectionId String?
  createdAt   DateTime            @default(now())
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  article     Article             @relation(fields: [articleId], references: [id], onDelete: Cascade)
  collection  BookmarkCollection? @relation(fields: [collectionId], references: [id], onDelete: SetNull)

  @@id([userId, articleId])
  @@index([collectionId, createdAt])
}

model BookmarkCollection {
  id        String     @id @default(cuid())
  userId    String
  name      String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookmarks Bookmark[]

  @@unique([userId, name])
}

model Follow {
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  follower    User     @relation("following", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("followers", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
  @@index([followingId, followerId])
}

model ArticleView {
  id                  String   @id @default(cuid())
  articleId           String
  userId              String?
  anonymousId         String?
  sessionHash         String
  referrer            String?
  deviceType          String?
  viewedAt            DateTime @default(now())
  readingDuration     Int      @default(0)
  completionPercentage Int     @default(0)
  article             Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  user                User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([articleId, viewedAt])
  @@index([userId, viewedAt])
}

model ArticleRevision {
  id            String   @id @default(cuid())
  articleId     String
  editorId      String
  version       Int
  title         String
  excerpt       String?
  content       String
  changeSummary String?
  createdAt     DateTime @default(now())
  article       Article   @relation(fields: [articleId], references: [id], onDelete: Cascade)
  editor        User      @relation(fields: [editorId], references: [id], onDelete: Cascade)

  @@unique([articleId, version])
  @@index([articleId, createdAt])
}

model ArticleActivity {
  id        String   @id @default(cuid())
  articleId String
  userId    String
  action    String
  metadata  Json?
  createdAt DateTime @default(now())
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([articleId, createdAt])
  @@index([userId, createdAt])
}

model Report {
  id           String       @id @default(cuid())
  reporterId   String
  articleId    String?
  commentId    String?
  reason       ReportReason
  details      String?
  status       ReportStatus @default(PENDING)
  reviewedById String?
  reviewedAt   DateTime?
  resolution   String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  reporter     User         @relation("reporterReports", fields: [reporterId], references: [id], onDelete: Cascade)
  article      Article?     @relation(fields: [articleId], references: [id], onDelete: Cascade)
  comment      Comment?     @relation(fields: [commentId], references: [id], onDelete: Cascade)
  reviewedBy   User?        @relation("reviewerReports", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  link      String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  targetId  String?
  targetType String?
  metadata  Json?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([action, createdAt])
}

model Upload {
  id         String        @id @default(cuid())
  userId     String
  purpose    UploadPurpose
  url        String
  publicId   String
  createdAt  DateTime      @default(now())
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ContactMessage {
  id          String               @id @default(cuid())
  name        String
  email       String
  topic       ContactTopic
  company     String?
  teamSize    String?
  message     String
  status      ContactMessageStatus @default(PENDING)
  handledById String?
  handledAt   DateTime?
  internalNotes String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  handledBy   User?                @relation("contactHandler", fields: [handledById], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([topic, createdAt])
  @@index([email, createdAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
